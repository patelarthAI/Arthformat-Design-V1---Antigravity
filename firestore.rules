rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Valid format for alphanumeric/dash IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // System Secret value check - used securely by Express server backend (ABAC)
    function isServerSecretValid(data) {
      return data.get('system_secret', '') == 'SERVER_SECRET_ee62ff41-5153-437f-b485-66227c47d53d';
    }

    // Test connection check allowing client-side or server-side base validation
    match /test/connection {
      allow read, write: if true;
    }

    match /resumes/{resumeId} {
      allow get: if resource == null || isServerSecretValid(resource.data);
      allow list: if isServerSecretValid(resource.data);
      allow create: if isValidId(resumeId) && isServerSecretValid(request.resource.data);
      allow update: if isValidId(resumeId) && isServerSecretValid(request.resource.data) && isServerSecretValid(resource.data);
      allow delete: if isServerSecretValid(resource.data);
    }

    match /activity_logs/{logId} {
      allow get: if resource == null || isServerSecretValid(resource.data);
      allow list: if isServerSecretValid(resource.data);
      allow create: if isValidId(logId) && isServerSecretValid(request.resource.data);
      allow update, delete: if false; // Logs are immutable
    }
  }
}
